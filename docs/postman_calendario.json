              "raw": "{{base_url}}/api/v1/calendario",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "calendario"]
            }
          }
        },
        {
          "name": "Crear actividad con cliente y proyecto",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"titulo\": \"Demo con cliente\",\n  \"descripcion\": \"Presentación de avances del proyecto\",\n  \"tipoActividadId\": 1,\n  \"inicioEn\": \"2026-04-10T15:00:00-03:00\",\n  \"finEn\":    \"2026-04-10T16:30:00-03:00\",\n  \"todoDia\": false,\n  \"zonaHoraria\": \"America/Argentina/Cordoba\",\n  \"clienteId\": 1,\n  \"proyectoId\": 1,\n  \"ubicacion\": null,\n  \"urlReunion\": \"https://meet.google.com/xyz-abc-def\",\n  \"visibilidad\": 2,\n  \"participantesIds\": [2],\n  \"recordatorios\": [\n    { \"minutosAntes\": 30, \"canal\": 1 }\n  ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/calendario",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "calendario"]
            }
          }
        },
        {
          "name": "Obtener actividad por ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/calendario/1",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "calendario", "1"]
            }
          }
        },
        {
          "name": "Mis actividades del mes (calendar view)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/calendario/mis-actividades?year=2026&month=4",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "calendario", "mis-actividades"],
              "query": [
                { "key": "year",  "value": "2026" },
                { "key": "month", "value": "4" }
              ]
            }
          }
        },
        {
          "name": "Modificar actividad",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"titulo\": \"Reunión de equipo (reprogramada)\",\n  \"descripcion\": \"Se cambió la hora\",\n  \"tipoActividadId\": null,\n  \"inicioEn\": \"2026-04-01T14:00:00-03:00\",\n  \"finEn\":    \"2026-04-01T15:00:00-03:00\",\n  \"todoDia\": null,\n  \"zonaHoraria\": null,\n  \"clienteId\": null,\n  \"proyectoId\": null,\n  \"ubicacion\": \"Sala B\",\n  \"urlReunion\": null,\n  \"visibilidad\": null,\n  \"participantesIds\": [2, 4],\n  \"recordatorios\": [\n    { \"minutosAntes\": 10, \"canal\": 1 }\n  ]\n}"
