{
  "info": {
    "name": "Chemi - Calendario",
    "_postman_id": "chemi-calendario-v1",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:5000", "type": "string" },
    { "key": "token",    "value": "TU_JWT_ACA",            "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Tipos de Actividad",
      "item": [
        {
          "name": "Listar tipos activos",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/tipos-actividad",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "tipos-actividad"]
            }
          }
        },
        {
          "name": "Crear tipo de actividad",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/tipos-actividad?nombre=Reunión&color=%231D4ED8",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "tipos-actividad"],
              "query": [
                { "key": "nombre", "value": "Reunión" },
                { "key": "color",  "value": "#1D4ED8" }
              ]
            }
          }
        },
        {
          "name": "Modificar tipo de actividad",
          "request": {
            "method": "PUT",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/tipos-actividad/1?nombre=Reunión interna&color=%230F766E",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "tipos-actividad", "1"],
              "query": [
                { "key": "nombre", "value": "Reunión interna" },
                { "key": "color",  "value": "#0F766E" }
              ]
            }
          }
        },
        {
          "name": "Eliminar tipo de actividad",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/tipos-actividad/1",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "tipos-actividad", "1"]
            }
          }
        }
      ]
    },
    {
      "name": "Calendario",
      "item": [
        {
          "name": "Crear actividad",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"titulo\": \"Reunión de equipo\",\n  \"descripcion\": \"Revisión semanal del sprint\",\n  \"tipoActividadId\": 1,\n  \"inicioEn\": \"2026-04-01T10:00:00-03:00\",\n  \"finEn\":    \"2026-04-01T11:00:00-03:00\",\n  \"todoDia\": false,\n  \"zonaHoraria\": \"America/Argentina/Cordoba\",\n  \"clienteId\": null,\n  \"proyectoId\": null,\n  \"ubicacion\": \"Sala de reuniones\",\n  \"urlReunion\": null,\n  \"visibilidad\": 1,\n  \"participantesIds\": [2, 3],\n  \"recordatorios\": [\n    { \"minutosAntes\": 15, \"canal\": 1 },\n    { \"minutosAntes\": 60, \"canal\": 1 }\n  ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/calendario",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "calendario"]
            }
          }
        },
        {
          "name": "Crear actividad todo el día",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"titulo\": \"Capacitación React\",\n  \"descripcion\": \"Día completo de capacitación\",\n  \"tipoActividadId\": null,\n  \"inicioEn\": \"2026-04-05T00:00:00-03:00\",\n  \"finEn\":    \"2026-04-05T23:59:59-03:00\",\n  \"todoDia\": true,\n  \"zonaHoraria\": \"America/Argentina/Cordoba\",\n  \"clienteId\": null,\n  \"proyectoId\": null,\n  \"ubicacion\": null,\n  \"urlReunion\": null,\n  \"visibilidad\": 1,\n  \"participantesIds\": [],\n  \"recordatorios\": []\n}"
